rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "rm0628500741@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('preferredLanguage' in data) || (data.preferredLanguage in ['ar', 'fr', 'en'])) &&
             (!('skills' in data) || (data.skills is list && data.skills.size() <= 50)) &&
             (!('isAdmin' in data) || (data.isAdmin is bool));
    }

    function isValidCRSAnalysis(data) {
      return data.keys().hasAll(['uid', 'answers', 'result']) &&
             data.uid == request.auth.uid &&
             data.answers is map &&
             data.result is map;
    }

    function isValidCV(data) {
      return data.keys().hasAll(['userId', 'fullName']) &&
             data.userId == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 200;
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email', 'type', 'message', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.status in ['pending', 'accepted', 'completed'] &&
             data.createdAt is timestamp;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['uid', 'jobId', 'jobTitle', 'company', 'appliedAt', 'status']) &&
             data.uid == request.auth.uid &&
             data.jobTitle is string && data.jobTitle.size() <= 200 &&
             data.company is string && data.company.size() <= 200 &&
             data.appliedAt is timestamp;
    }

    // --- Collections ---

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && !('isAdmin' in incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'preferredLanguage', 'cv_completed', 'profession', 'lastJob', 'skills', 'goal', 'hasCV', 'updatedAt', 'profileCompletion']) &&
                    !('isAdmin' in incoming().diff(existing()).affectedKeys());
      allow update: if isAdmin();
    }

    match /crs_analyses/{analysisId} {
      allow get: if isSignedIn() && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidCRSAnalysis(incoming());
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /cvs/{cvId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCV(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /consultations/{consultationId} {
      allow get: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidConsultation(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin() && 
                    incoming().diff(existing()).affectedKeys().hasAny(['status', 'reply', 'repliedAt', 'message', 'fullName', 'country', 'email', 'type']);
      allow update: if isSignedIn() && isOwner(existing().uid) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['message', 'fullName', 'country']) &&
                    isValidConsultation(incoming());
      allow delete: if isAdmin();
    }

    match /applications/{applicationId} {
      allow get: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidApplication(incoming());
      allow update: if isSignedIn() && existing().uid == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow update: if isAdmin();
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }
  }
}
